{
  "name": "executable-markdown-agents",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "description": "Executable MDX — durable markdown workflows with component expansion and code execution",
  "exports": {
    ".": "./mod.ts"
  },
  "bin": {
    "ema": "./bin/ema.js"
  },
  "scripts": {
    "ema": "node --experimental-strip-types src/cli.ts",
    "test": "node --test --experimental-strip-types 'tests/**/*.test.ts'",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effectionx/converge": "^0.1.3",
    "@effectionx/durable-effects": "https://pkg.pr.new/thefrontside/effectionx/@effectionx/durable-effects@46a6855",
    "@effectionx/durable-streams": "https://pkg.pr.new/thefrontside/effectionx/@effectionx/durable-streams@e909b25",
    "@effectionx/fetch": "^0.1.2",
    "@effectionx/middleware": "0.1.0",
    "@effectionx/node": "^0.2.2",
    "@effectionx/process": "^0.7.3",
    "@effectionx/scope-eval": "^0.1.2",
    "@effectionx/timebox": "^0.4.2",
    "@frontside/configliere": "npm:@jsr/frontside__configliere@^0.2.3",
    "acorn": "^8.16.0",
    "effection": "4.1.0-alpha.7",
    "gray-matter": "^4.0.3",
    "magic-string": "^0.30.21",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "remend": "^1.2.2"
  },
  "devDependencies": {
    "@effectionx/bdd": "^0.5.1",
    "@std/expect": "npm:@jsr/std__expect@^1.0.18",
    "@types/node": "^22.0.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "@effectionx/durable-streams": "https://pkg.pr.new/thefrontside/effectionx/@effectionx/durable-streams@e909b25"
    }
  }
}
