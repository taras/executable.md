{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@executablemd/core": ["./packages/core/mod.ts"],
      "@executablemd/runtime": ["./packages/runtime/mod.ts"],
      "@executablemd/runtime/test": ["./packages/runtime/test/mod.ts"],
      "@executablemd/durable-streams": ["./packages/durable-streams/mod.ts"],
      "@executablemd/code-review-agent": ["./packages/code-review-agent/mod.ts"],
      "@effectionx/bdd/node": ["./packages/test-support/bdd.ts"],
      "@effectionx/bdd/expect": ["./packages/test-support/expect.ts"]
    }
  },
  "include": [
    "packages/core/**/*.ts",
    "packages/durable-streams/**/*.ts",
    "packages/runtime/**/*.ts",
    "packages/code-review-agent/**/*.ts",
    "packages/test-support/**/*.ts"
  ],
  "exclude": [
    "packages/durable-streams/demo/**"
  ]
}
